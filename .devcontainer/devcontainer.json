{
  "name": "AI Sandbox (Compose)",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "ai-sandbox",  // Service name in your compose
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",  // Stops all services
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "forwardPorts": [3000],  // Grafana, etc.
  "postCreateCommand": "opencode models && claude-monitor --help",
  "remoteEnv": {
    "BUN_INSTALL": "/bun",
    "PATH": "/home/aiuser/.local/bin:/bun/bin:/usr/local/bin:${PATH}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code-vscode",
        "google-cloudtools.cloudcode"
      ]
    }
  }
}
